<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanh.Pages.TrackingPage"
             Title="Theo Dõi"
             Padding="0"
             BackgroundColor="#FAFAFA">

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

        <!-- Header -->
        <StackLayout Grid.Row="0" Padding="16,8" BackgroundColor="#FFFFFF" Spacing="0">
            <HorizontalStackLayout Spacing="12" Padding="0,8">
                <Label Text="🎯 Theo Dõi" 
                       FontSize="20" 
                       FontAttributes="Bold"
                       TextColor="#1F1F1F"
                       VerticalOptions="Center"
                       HorizontalOptions="FillAndExpand"/>
            </HorizontalStackLayout>
        </StackLayout>

        <!-- Content -->
        <StackLayout Grid.Row="1" BackgroundColor="#FFFFFF" Padding="24" Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
            <Label Text="🎯 Theo Dõi" FontSize="24" FontAttributes="Bold" TextColor="#1F1F1F" HorizontalOptions="Center"/>
            <Label Text="Kích hoạt theo dõi để bắt đầu" FontSize="14" TextColor="#999999" HorizontalOptions="Center" Margin="0,12,0,0"/>
            <Label x:Name="TrackingStatusLabel" Text="Trạng thái: Chưa bắt đầu" FontSize="12" TextColor="#666666" HorizontalOptions="Center" Margin="0,24,0,0"/>
        </StackLayout>

        <!-- Tracking Button -->
        <StackLayout Grid.Row="2" Padding="16" BackgroundColor="#FFFFFF" Spacing="8">
            <Button x:Name="TrackingButton" 
                   Text="▶️ BẮT ĐẦU THEO DÕI" 
                   Clicked="OnTrackingToggled" 
                   BackgroundColor="#FF6B35" 
                   TextColor="White" 
                   CornerRadius="8" 
                   Padding="16,12" 
                   FontSize="13"
                   FontAttributes="Bold"
                   BorderWidth="0"
                   HorizontalOptions="FillAndExpand"/>
            <Label x:Name="StatusLabel" 
                  Text="Nhấn để bắt đầu theo dõi" 
                  TextColor="#999999" 
                  FontSize="12" 
                  HorizontalTextAlignment="Center"/>
        </StackLayout>
    </Grid>

</ContentPage>