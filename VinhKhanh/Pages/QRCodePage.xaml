<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="VinhKhanh.Pages.QRCodePage"
             Title="Quét Mã QR"
             BackgroundColor="#1F1F1F">

	<Grid RowDefinitions="*,60" RowSpacing="0">

		<!-- QR Scanner Container -->
		<Frame Grid.Row="0"
               CornerRadius="0"
               Padding="0"
               HasShadow="False"
               BorderColor="Transparent"
               BackgroundColor="#1F1F1F">

			<Grid BackgroundColor="Black">

				<!-- ZXing Camera View - Main Scanner -->
				<zxing:CameraBarcodeReaderView
                    x:Name="QRScannerView"
                    BarcodesDetected="OnBarcodesDetected"
                    CameraLocation="Rear"
                    IsDetecting="True"
                    IsEnabled="True"
                    Grid.Row="0"
                    Grid.Column="0"/>

				<!-- Overlay Scanner Frame - Phải có InputTransparent="True" để không chặn camera -->
				<Grid RowDefinitions="*,250,*"
                      ColumnDefinitions="*,250,*"
                      InputTransparent="True"
                      BackgroundColor="Transparent"
                      Grid.Row="0"
                      Grid.Column="0">

					<!-- Góc trên trái - Tối -->
					<BoxView Grid.Row="0" Grid.Column="0"
                             Opacity="0.4"
                             BackgroundColor="Black"/>

					<!-- Góc trên giữa - Tối -->
					<BoxView Grid.Row="0" Grid.Column="1"
                             Opacity="0.4"
                             BackgroundColor="Black"/>

					<!-- Góc trên phải - Tối -->
					<BoxView Grid.Row="0" Grid.Column="2"
                             Opacity="0.4"
                             BackgroundColor="Black"/>

					<!-- Khung quét ở giữa - Trong suốt để thấy camera -->
					<Border Grid.Row="1" Grid.Column="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="0"
                            Stroke="#FF6B35"
                            BackgroundColor="Transparent"
                            StrokeThickness="3"/>

					<!-- Góc dưới trái - Tối -->
					<BoxView Grid.Row="2" Grid.Column="0"
                             Opacity="0.4"
                             BackgroundColor="Black"/>

					<!-- Góc dưới giữa - Tối -->
					<BoxView Grid.Row="2" Grid.Column="1"
                             Opacity="0.4"
                             BackgroundColor="Black"/>

					<!-- Góc dưới phải - Tối -->
					<BoxView Grid.Row="2" Grid.Column="2"
                             Opacity="0.4"
                             BackgroundColor="Black"/>
				</Grid>
			</Grid>
		</Frame>

		<!-- Bottom QR Instruction -->
		<Frame Grid.Row="1"
               CornerRadius="0"
               Padding="0"
               HasShadow="False"
               BorderColor="Transparent"
               BackgroundColor="#1F1F1F">

			<Grid ColumnDefinitions="*,Auto" Padding="12,0" VerticalOptions="Center">
				<Label x:Name="InstructionLabel"
                       Grid.Column="0"
                       Text="📱 Point camera at QR code"
                       FontSize="14"
                       TextColor="White"
                       VerticalOptions="Center"/>

				<Button x:Name="PickImageButton"
                        Grid.Column="1"
                        Text="🖼️"
                        FontSize="16"
                        WidthRequest="44"
                        HeightRequest="44"
                        CornerRadius="22"
                        Padding="0"
                        BackgroundColor="#FF6B35"
                        TextColor="White"
                        Clicked="OnPickImageClicked"/>
			</Grid>
		</Frame>

	</Grid>

</ContentPage>