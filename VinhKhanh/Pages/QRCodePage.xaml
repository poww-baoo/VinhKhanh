<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanh.Pages.QRCodePage"
             Title="Quét Mã QR"
             BackgroundColor="#1F1F1F">

    <Grid RowDefinitions="*,60" RowSpacing="0">
        
        <!-- QR Scanner -->
        <Frame Grid.Row="0" 
               CornerRadius="0" 
               Padding="0" 
               HasShadow="False" 
               BorderColor="Transparent"
               BackgroundColor="#1F1F1F">
            <Grid>
                <WebView x:Name="QRScannerWebView" BackgroundColor="#1F1F1F"/>
                <StackLayout Padding="16" VerticalOptions="End" HorizontalOptions="End" Spacing="8">
                    <Button x:Name="FlashlightToggleButton" 
                            Text="🔦" 
                            Clicked="OnFlashlightToggleClicked"
                            BackgroundColor="#FF6B35"
                            TextColor="White"
                            WidthRequest="50"
                            HeightRequest="50"
                            CornerRadius="25"
                            Padding="0"
                            BorderWidth="0"
                            FontSize="24"/>
                </StackLayout>
            </Grid>
        </Frame>

        <!-- Bottom QR Icon -->
        <Frame Grid.Row="1" 
               CornerRadius="0" 
               Padding="0" 
               HasShadow="False" 
               BorderColor="Transparent"
               BackgroundColor="#1F1F1F">
            <Grid HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="📱" 
                       FontSize="28" 
                       HorizontalOptions="Center" 
                       VerticalOptions="Center"/>
            </Grid>
        </Frame>

    </Grid>

</ContentPage>