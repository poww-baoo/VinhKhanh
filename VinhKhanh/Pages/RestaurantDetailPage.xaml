<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:VinhKhanh.Models"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="VinhKhanh.Pages.RestaurantDetailPage">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16" BackgroundColor="#F5F5F5">
            <StackLayout Spacing="8">
                <Frame CornerRadius="12" Padding="0" HasShadow="True" HeightRequest="200">
                    <Image Source="{Binding DisplayImage}" Aspect="AspectFill" HeightRequest="200" />
                </Frame>

                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10">
                    <Label x:Name="RestaurantNameLabel"
                           Grid.Row="0"
                           Grid.Column="0"
                           FontSize="24"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />

                    <Button x:Name="SaveButton"
                            Grid.Row="0"
                            Grid.Column="1"
                            Clicked="OnSaveButtonClicked"
                            WidthRequest="44"
                            HeightRequest="44"
                            CornerRadius="22"
                            Padding="0"
                            FontSize="18"
                            FontAttributes="Bold"
                            BorderWidth="0"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            Text="☆" />

                    <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="8" Margin="0,4,0,0">
                        <Label x:Name="YearLabel" FontSize="12" TextColor="#7F8C8D"/>
                        <Label Text="•" TextColor="#7F8C8D"/>
                        <Label x:Name="RatingLabel" FontSize="12" TextColor="#F39C12"/>
                    </HorizontalStackLayout>
                </Grid>
            </StackLayout>

            <Frame CornerRadius="12" Padding="12" BorderColor="#3498DB">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="HistoryTitleLabel" FontSize="16" FontAttributes="Bold"/>
                    <Label x:Name="HistoryLabel" FontSize="12" LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BorderColor="#1ABC9C">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="IntroTitleLabel" FontSize="16" FontAttributes="Bold"/>
                    <Label x:Name="IntroLabel" FontSize="12" LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BorderColor="#16A085">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="AddressTitleLabel" FontSize="16" FontAttributes="Bold"/>
                    <Label x:Name="AddressLabel" FontSize="12" LineBreakMode="WordWrap" TextColor="#1F1F1F"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BorderColor="#E74C3C">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="SignatureDishTitleLabel" FontSize="16" FontAttributes="Bold"/>
                    <Label x:Name="SignatureDishLabel" FontSize="14" FontAttributes="Bold"/>
                    <Label x:Name="SignatureDishStoryLabel" FontSize="12" LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BorderColor="#F39C12">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="NarrationLanguageLabel" FontSize="16" FontAttributes="Bold"/>

                    <HorizontalStackLayout Spacing="10" Margin="0,6,0,0">
                        <Button x:Name="ViOptionButton" Clicked="OnAudioOptionClicked" CommandParameter="vi" BackgroundColor="#FF6B35" TextColor="White" Padding="14,10" CornerRadius="10" FontSize="12" FontAttributes="Bold" BorderWidth="0"/>
                        <Button x:Name="EnOptionButton" Clicked="OnAudioOptionClicked" CommandParameter="en" BackgroundColor="#E0E0E0" TextColor="#1F1F1F" Padding="14,10" CornerRadius="10" FontSize="12" FontAttributes="Bold" BorderWidth="0"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10" Margin="0,4,0,0">
                        <Button x:Name="ZhOptionButton" Clicked="OnAudioOptionClicked" CommandParameter="zh" BackgroundColor="#E0E0E0" TextColor="#1F1F1F" Padding="14,10" CornerRadius="10" FontSize="12" FontAttributes="Bold" BorderWidth="0"/>
                        <Button x:Name="JaOptionButton" Clicked="OnAudioOptionClicked" CommandParameter="ja" BackgroundColor="#E0E0E0" TextColor="#1F1F1F" Padding="14,10" CornerRadius="10" FontSize="12" FontAttributes="Bold" BorderWidth="0"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10" Margin="0,4,0,0">
                        <Button x:Name="RuOptionButton" Clicked="OnAudioOptionClicked" CommandParameter="ru" BackgroundColor="#E0E0E0" TextColor="#1F1F1F" Padding="14,10" CornerRadius="10" FontSize="12" FontAttributes="Bold" BorderWidth="0"/>
                        <Button x:Name="FrOptionButton" Clicked="OnAudioOptionClicked" CommandParameter="fr" BackgroundColor="#E0E0E0" TextColor="#1F1F1F" Padding="14,10" CornerRadius="10" FontSize="12" FontAttributes="Bold" BorderWidth="0"/>
                    </HorizontalStackLayout>

                    <Button x:Name="PlaySignatureButton" Clicked="OnPlaySignatureDish" Margin="0,8,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BorderColor="#9B59B6">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="MenuTitleLabel" FontSize="16" FontAttributes="Bold"/>
                    <CollectionView x:Name="MenuCollection" HeightRequest="180">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:PoiMenuItem">
                                <Frame CornerRadius="8" Padding="10" BorderColor="#ECF0F1">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}" FontSize="13" FontAttributes="Bold"/>
                                        <Label Text="{Binding Description}" FontSize="11" TextColor="#666666"/>
                                        <Label Text="{Binding PriceText}" FontSize="11" TextColor="#FF6B35"/>
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BorderColor="#2C3E50">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="PlaybackControlTitleLabel" FontSize="14" FontAttributes="Bold"/>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Button x:Name="PlayButton" Text="▶️" Clicked="OnPlayClicked" Padding="12"/>
                        <Button x:Name="PauseButton" Text="⏸️" Clicked="OnPauseClicked" Padding="12"/>
                        <Button x:Name="StopButton" Text="⏹️" Clicked="OnStopClicked" Padding="12"/>
                    </HorizontalStackLayout>
                    <ProgressBar x:Name="PlaybackProgress" Progress="0" Margin="0,8,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BorderColor="#34495E">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label x:Name="QrTitleLabel" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    <zxing:BarcodeGeneratorView x:Name="PoiQrCodeView"
                                                WidthRequest="180"
                                                HeightRequest="180"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center" />
                    <Label x:Name="QrContentLabel"
                           FontSize="11"
                           TextColor="#7F8C8D"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>