<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:VinhKhanh.Models"
             x:Class="VinhKhanh.Pages.SavedPage"
             Title="Đã Lưu"
             Padding="0"
             BackgroundColor="#FAFAFA">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- Header -->
        <StackLayout Grid.Row="0" Padding="16,8" BackgroundColor="#FFFFFF" Spacing="0">
            <HorizontalStackLayout Spacing="12" Padding="0,8">
                <Label Text="📍 Đã Lưu" 
                       FontSize="20" 
                       FontAttributes="Bold"
                       TextColor="#1F1F1F"
                       VerticalOptions="Center"
                       HorizontalOptions="FillAndExpand"/>
            </HorizontalStackLayout>
        </StackLayout>

        <!-- Content -->
        <StackLayout Grid.Row="1" BackgroundColor="#FFFFFF" Padding="24" Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
            <Label Text="📍 Đã Lưu" FontSize="24" FontAttributes="Bold" TextColor="#1F1F1F" HorizontalOptions="Center"/>
            <Label Text="Chưa có quán ăn nào được lưu" FontSize="14" TextColor="#999999" HorizontalOptions="Center" Margin="0,12,0,0"/>
        </StackLayout>
    </Grid>

</ContentPage>