<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanh.Pages.MainPage"
             Title=""
             Padding="0"
             BackgroundColor="#FFFFFF">
    <Grid RowDefinitions="*,Auto" RowSpacing="0">
        
        <!-- Content Container -->
        <Grid Grid.Row="0" x:Name="ContentFrame" Padding="0"/>

        <!-- Bottom Navigation Bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*" BackgroundColor="#FFFFFF" Padding="0" RowSpacing="0" ColumnSpacing="0">
            <BoxView Grid.Row="0" Grid.ColumnSpan="5" BackgroundColor="#E0E0E0" HeightRequest="0.5"/>
            
            <!-- Explore Tab -->
            <StackLayout Grid.Column="0" Spacing="4" Padding="12" 
                        x:Name="ExploreTab" 
                        BackgroundColor="#FFFFFF"
                        Opacity="1.0">
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="explore"/>
                </StackLayout.GestureRecognizers>
                <Label Text="🏠" FontSize="20" HorizontalOptions="Center"/>
                <Label Text="Khám phá" FontSize="10" TextColor="#FF6B35" HorizontalOptions="Center" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
            </StackLayout>

            <!-- Saved Tab -->
            <StackLayout Grid.Column="1" Spacing="4" Padding="12" 
                        x:Name="SavedTab" 
                        BackgroundColor="#FFFFFF"
                        Opacity="0.5">
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="saved"/>
                </StackLayout.GestureRecognizers>
                <Label Text="📍" FontSize="20" HorizontalOptions="Center"/>
                <Label Text="Đã Lưu" FontSize="10" TextColor="#666666" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            </StackLayout>

            <!-- QR Code Tab (Centered) -->
            <StackLayout Grid.Column="2" Spacing="4" Padding="12" 
            x:Name="QRCodeTab" 
            BackgroundColor="#FFFFFF"
            Opacity="0.5">
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="qrcode"/>
                </StackLayout.GestureRecognizers>
                <Image Source="qrcode_icon.svg" 
                       WidthRequest="20" 
                       HeightRequest="20" 
                       HorizontalOptions="Center"
                       Aspect="AspectFit"/>
                <Label Text="Quét QR" FontSize="10" TextColor="#666666" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            </StackLayout>

            <!-- Tracking Tab -->
            <StackLayout Grid.Column="3" Spacing="4" Padding="12" 
                        x:Name="TrackingTab" 
                        BackgroundColor="#FFFFFF"
                        Opacity="0.5">
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="tracking"/>
                </StackLayout.GestureRecognizers>
                <Label Text="🎯" FontSize="20" HorizontalOptions="Center"/>
                <Label Text="Theo Dõi" FontSize="10" TextColor="#666666" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            </StackLayout>

            <!-- Settings Tab -->
            <StackLayout Grid.Column="4" Spacing="4" Padding="12" 
                        x:Name="SettingsTab" 
                        BackgroundColor="#FFFFFF"
                        Opacity="0.5">
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="settings"/>
                </StackLayout.GestureRecognizers>
                <Label Text="⚙️" FontSize="20" HorizontalOptions="Center"/>
                <Label Text="Cài đặt" FontSize="10" TextColor="#666666" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            </StackLayout>
        </Grid>
    </Grid>
</ContentPage>